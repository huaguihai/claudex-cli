{
  "name": "claudex-cli",
  "version": "0.1.0",
  "description": "Interactive multi-provider manager for Claude Code settings",
  "type": "module",
  "bin": {
    "claudex": "./bin/claudex.js"
  },
  "scripts": {
    "start": "node ./bin/claudex.js",
    "lint": "node ./bin/claudex.js --help",
    "benchmark:native": "node ./scripts/run-native-benchmark.js",
    "benchmark:native:summary": "node ./scripts/summarize-native-benchmark.js",
    "benchmark:native:autotune": "node ./scripts/generate-native-autotune.js",
    "benchmark:native:dashboard": "node ./scripts/render-native-dashboard.js",
    "benchmark:native:replay": "node ./scripts/run-native-replay.js",
    "benchmark:native:smoke": "node ./scripts/run-native-smoke.js",
    "benchmark:native:all": "npm run benchmark:native && npm run benchmark:native:summary && npm run benchmark:native:autotune && npm run benchmark:native:dashboard && npm run benchmark:native:smoke"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
